      <description>&lt;img src=&#34;img/tb-logo.jpg&#34; alt=&#34;Treatment Bank&#34; class=&#34;tb-logo&#34;&gt;&#xA;&lt;div class=&#34;widget-search widget&#34;&gt;&#xA;&#x9;&lt;!-- http://tb.plazi.org/GgServer/search?fullText.matchMode=prefix&amp;fullText.ftQuery= --&gt;&#xA;    &lt;h2&gt;Find treatments&lt;/h2&gt;&#xA;    &lt;form id=&#34;tb&#34; role=&#34;search&#34; target=&#34;_blank&#34; &#xA;        method=&#34;get&#34; action=&#34;https://tb.plazi.org/GgServer/search&#34;&gt;&#xA;        &lt;details open&gt;&#xA;            &lt;summary&gt;By Full Text Search&lt;/summary&gt;&#xA;            &lt;input class=&#34;form-control&#34; type=&#34;search&#34; &#xA;                placeholder=&#34;enter anything&#34; id=&#34;fullText.ftQuery&#34; &#xA;                name=&#34;fullText.ftQuery&#34; aria-label=&#34;find treatments&#34;&gt;&#xA;        &lt;/details&gt;&#xA;    &lt;div id=&#34;search_results&#34;&gt;&lt;/div&gt;&#xA;        &lt;details&gt;&#xA;            &lt;summary&gt;By Taxonomic Names&lt;/summary&gt;&#xA;            &lt;div&gt;&#xA;                &lt;input class=&#34;form-control&#34; &#xA;                    name=&#34;taxonomicName.taxonomicName&#34; &#xA;                    placeholder=&#34;taxon name&#34; &#xA;                    title=&#34;Taxonomic name as a whole&#34; type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; &#xA;                    name=&#34;taxonomicName.order&#34; placeholder=&#34;order&#34; &#xA;                    title=&#34;Search for Superorder, Order, Suborder, Infraorder (might not all be given for each taxon)&#34; &#xA;                    type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; &#xA;                    name=&#34;taxonomicName.family&#34; placeholder=&#34;family&#34; &#xA;                    title=&#34;Search for Superfamily, Family, Subfamily, Infrafamily, Supertribe, Tribe, Subtribe, Infratribe (might not all be given for each taxon)&#34; &#xA;                    type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; placeholder=&#34;genus&#34; &#xA;                    name=&#34;taxonomicName.genus&#34; &#xA;                    title=&#34;Search for Genus, Subgenus, Infragenus, Section, Subsection, Series, Subseries (might not all be given for each taxon)&#34; &#xA;                    type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; placeholder=&#34;species&#34; &#xA;                    name=&#34;taxonomicName.species&#34; &#xA;                    title=&#34;Search for Species aggregate, Species, Subspecies, Infraspecies, Variety, Subvariety, Form, Subform (might not all be given for each taxon)&#34; &#xA;                    type=&#34;search&#34;&gt;&#xA;                &lt;label&gt;Taxa Only &lt;input checked=&#34;checked&#34; &#xA;                    name=&#34;taxonomicName.isNomenclature&#34; &#xA;                    title=&#34;Restrict search to treatment taxa&#34; &#xA;                    type=&#34;checkbox&#34; value=&#34;true&#34;&gt;&lt;/label&gt;&#xA;                &lt;label&gt;Exact Match &lt;input checked=&#34;checked&#34; &#xA;                    name=&#34;taxonomicName.exactMatch&#34; &#xA;                    title=&#34;Match all rank group specific epithets given below&#34; &#xA;                    type=&#34;checkbox&#34; value=&#34;true&#34;&gt;&lt;/label&gt;&#xA;                &lt;label&gt;Synonyms &lt;input name=&#34;taxonomicName.includeSynonyms&#34; &#xA;                    title=&#34;Include synonyms in search result (for whole-name search only, implies exact match)?&#34; &#xA;                    type=&#34;checkbox&#34; value=&#34;true&#34;&gt;&lt;/label&gt;&#xA;            &lt;/div&gt;&#xA;        &lt;/details&gt;&#xA;        &lt;details&gt;&#xA;            &lt;summary&gt;By Bibliographic Data&lt;/summary&gt;&#xA;            &lt;div&gt;&#xA;                &lt;input class=&#34;form-control&#34; name=&#34;BibMetaData.docAuthor&#34; &#xA;                    placeholder=&#34;author&#34; &#xA;                    title=&#34;Document Author&#34; type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; name=&#34;BibMetaData.docDate&#34; &#xA;                    placeholder=&#34;year&#34; &#xA;                    title=&#34;Year of Publication&#34; type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; name=&#34;BibMetaData.docTitle&#34; &#xA;                    placeholder=&#34;title&#34; &#xA;                    title=&#34;Document Title&#34; type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; name=&#34;BibMetaData.docOrigin&#34; &#xA;                    placeholder=&#34;journal/publisher&#34; &#xA;                    title=&#34;Name of Journal for Articles, Name of Publisher for Books and Book Chapters&#34; &#xA;                    type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; name=&#34;BibMetaData.part&#34; &#xA;                    placeholder=&#34;volume/issue&#34; &#xA;                    title=&#34;Volume or Issue Number of Journals&#34; type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; name=&#34;BibMetaData.pageNumber&#34; &#xA;                    placeholder=&#34;page&#34; &#xA;                    title=&#34;Page Number&#34; type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; name=&#34;BibMetaData.extId&#34; &#xA;                    placeholder=&#34;identifier (DOI/ISBN/Handle)&#34;&#xA;                    title=&#34;External Identifier (DOI, Handle, ISBN, etc.)&#34; &#xA;                    type=&#34;search&#34;&gt;&#xA;            &lt;/div&gt;&#xA;        &lt;/details&gt;&#xA;        &lt;details&gt;&#xA;            &lt;summary&gt;By Material Citations&lt;/summary&gt;&#xA;            &lt;div&gt;&#xA;                &lt;input class=&#34;form-control&#34; name=&#34;materialsCitation.location&#34; &#xA;                    placeholder=&#34;location text&#34; &#xA;                    title=&#34;General location description, to match against all respective fields, i.e., Country, State / Province, and Location Name&#34; &#xA;                    type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; placeholder=&#34;country&#34;&#xA;                    name=&#34;materialsCitation.country&#34; &#xA;                    title=&#34;Name of country where specimens where collected&#34; &#xA;                    type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; placeholder=&#34;state/province&#34;&#xA;                    name=&#34;materialsCitation.stateProvince&#34; &#xA;                    title=&#34;Name of administrative sub division of country&#34; &#xA;                    type=&#34;search&#34;&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;div&gt;&#xA;                &lt;label&gt;Type Status&#xA;                    &lt;select class=&#34;form-control&#34; &#xA;                        name=&#34;materialsCitation.typeStatus&#34; &#xA;                        title=&#34;Type status of specimen as indicated in publication&#34;&gt;&#xA;                        &lt;option&gt;All Types&lt;/option&gt;&#xA;                        &lt;option&gt;Androtype&lt;/option&gt;&#xA;                        &lt;option&gt;Gynotype&lt;/option&gt;&#xA;                        &lt;option&gt;Holotype&lt;/option&gt;&#xA;                        &lt;option&gt;Lectotype&lt;/option&gt;&#xA;                        &lt;option&gt;Neotype&lt;/option&gt;&#xA;                        &lt;option&gt;Nidotype&lt;/option&gt;&#xA;                        &lt;option&gt;Paralectotype&lt;/option&gt;&#xA;                        &lt;option&gt;Paratype&lt;/option&gt;&#xA;                        &lt;option&gt;Syntype&lt;/option&gt;&#xA;                    &lt;/select&gt;&#xA;                &lt;/label&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;div&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; &#xA;                    placeholder=&#34;collection code&#34; &#xA;                    name=&#34;materialsCitation.collectionCode&#34; &#xA;                    title=&#34;Letter code of collection where specimens are stored&#34; &#xA;                    type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; &#xA;                    placeholder=&#34;specimen code&#34;&#xA;                    name=&#34;materialsCitation.specimenCode&#34; &#xA;                    title=&#34;Code of specimen within collection&#34; type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control&#34; name=&#34;materialsCitation.LSID&#34; &#xA;                    placeholder=&#34;LSID&#34; &#xA;                    title=&#34;Specimen LSID&#34; type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; name=&#34;materialsCitation.longitude&#34; &#xA;                    placeholder=&#34;longitude&#34;&#xA;                    title=&#34;Geographic longitude, in signed decimal degrees (positive: east, negative: west)&#34; &#xA;                    type=&#34;search&#34;&gt;&#xA;                &lt;input class=&#34;form-control-2&#34; name=&#34;materialsCitation.latitude&#34; &#xA;                    placeholder=&#34;latitude&#34;&#xA;                    title=&#34;Geographic latitude, in signed decimal degrees (positive: north, negative: south)&#34; &#xA;                    type=&#34;search&#34;&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;div&gt;&#xA;                &lt;label&gt;Lon/Lat +/-&#xA;                    &lt;select class=&#34;form-control&#34; &#xA;                        name=&#34;materialsCitation.degreeCircle&#34; &#xA;                        title=&#34;Maximum devition from logitude and latitude given in respective fields, in degrees&#34;&gt;&#xA;                        &lt;option value=&#34;0&#34;&gt;Exact&lt;/option&gt;&#xA;                        &lt;option value=&#34;1&#34; selected&gt;1°&lt;/option&gt;&#xA;                        &lt;option value=&#34;2&#34;&gt;2°&lt;/option&gt;&#xA;                        &lt;option value=&#34;3&#34;&gt;3°&lt;/option&gt;&#xA;                        &lt;option value=&#34;5&#34;&gt;5°&lt;/option&gt;&#xA;                        &lt;option value=&#34;10&#34;&gt;10°&lt;/option&gt;&#xA;                    &lt;/select&gt;&#xA;                &lt;/label&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;div&gt;&#xA;                &lt;input class=&#34;form-control&#34; name=&#34;materialsCitation.elevation&#34; &#xA;                    placeholder=&#34;elevation&#34; &#xA;                    title=&#34;Elevation above see level (negative: depth below see level)&#34; &#xA;                    type=&#34;text&#34;&gt;&#xA;            &lt;/div&gt;&#xA;            &lt;div&gt;&#xA;                &lt;label&gt;Elevation +/-&#xA;                    &lt;select class=&#34;form-control&#34; &#xA;                        name=&#34;materialsCitation.elevationCircle&#34; &#xA;                        title=&#34;Maximum devition from elevation given in respective field, in meters&#34;&gt;&#xA;                        &lt;option value=&#34;0&#34;&gt;Exact&lt;/option&gt;&#xA;                        &lt;option value=&#34;10&#34;&gt;10 m&lt;/option&gt;&#xA;                        &lt;option value=&#34;20&#34;&gt;20 m&lt;/option&gt;&#xA;                        &lt;option value=&#34;30&#34;&gt;30 m&lt;/option&gt;&#xA;                        &lt;option value=&#34;50&#34;&gt;50 m&lt;/option&gt;&#xA;                        &lt;option value=&#34;100&#34; selected&gt;100 m&lt;/option&gt;&#xA;                        &lt;option value=&#34;200&#34;&gt;200 m&lt;/option&gt;&#xA;                        &lt;option value=&#34;300&#34;&gt;300 m&lt;/option&gt;&#xA;                        &lt;option value=&#34;500&#34;&gt;500 m&lt;/option&gt;&#xA;                        &lt;option value=&#34;1000&#34;&gt;1000 m&lt;/option&gt;&#xA;                    &lt;/select&gt;&#xA;                &lt;/label&gt;&#xA;            &lt;/div&gt;&#xA;        &lt;/details&gt;&#xA;        &lt;input id=&#34;searchBtn2&#34; class=&#34;searchBtn&#34; type=&#34;submit&#34; value=&#34;Search&#34;&gt;&#xA;    &lt;/form&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;script&gt;&#xA;    // const search = function(e) {&#xA;    //     const q = document.getElementById(&#39;q&#39;)&#xA;    //     const search_results = document.getElementById(&#39;search_results&#39;)&#xA;    //     //const tb = &#39;https://tb.plazi.org/GgServer/search?fullText.matchMode=prefix&amp;fullText.ftQuery=&#39; + q.value&#xA;&#xA;    //     fetch(`https://test.zenodeo.org/v3/treatments?q=${q.value}`)&#xA;    //         .then(function(response) {&#xA;    //             if (!response.ok) {&#xA;    //                 throw new Error(&#39;HTTP error, status = &#39; + response.status);&#xA;    //             }&#xA;&#xA;    //             return response.json();&#xA;    //         })&#xA;    //         .then(function(response) {&#xA;    //             let res = &#39;&lt;h2&gt;Treatments search results&lt;/h2&gt;&#39;&#xA;    //             response.item.records.forEach(r =&gt; {&#xA;    //                 res += `&lt;details&gt;&#xA;    //                     &lt;summary&gt;${r.treatmentTitle}&lt;/summary&gt;&#xA;    //                     &lt;p&gt;${r.articleTitle}, ${r.journalTitle}&lt;/p&gt;</description>
